{
  "name": "math4js",
  "version": "0.1.0",
  "description": "A JavaScript/Node.js math library",
  "main": "src/math4js/index.js",
  "exports": {
    ".": "./dist/math4js/index.js",
    "./number_theory": "./dist/math4js/number_theory/index.js",
    "./linear_algebra": "./dist/math4js/linear_algebra/index.js",
    "./ndarray": "./dist/math4js/ndarray/index.js",
    "./ndarray/operations": "./dist/math4js/ndarray/operations.js",
    "./ndarray/random": "./dist/math4js/ndarray/random.js",
    "./statistics": "./dist/math4js/statistics/index.js",
    "./optimization": "./dist/math4js/optimization/index.js",
    "./calculus/derivative": "./dist/math4js/calculus/derivative.js",
    "./calculus/integral": "./dist/math4js/calculus/integral.js",
    "./calculus/multivariable": "./dist/math4js/calculus/multivariable.js",
    "./calculus/optimize": "./dist/math4js/calculus/optimize.js",
    "./geometry": "./dist/math4js/geometry/index.js",
    "./algebra/polynomial": "./dist/math4js/algebra/polynomial.js",
    "./algebra/roots": "./dist/math4js/algebra/roots.js",
    "./algebra/complex": "./dist/math4js/algebra/complex.js",
    "./algebra/rational": "./dist/math4js/algebra/rational.js"
  },
  "scripts": {
    "test": "jest",
    "lint": "eslint src test",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "keywords": [
    "math",
    "statistics",
    "random"
  ],
  "author": "ccc-js",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.4.9",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "jstat": "^1.9.6",
    "numeric": "^1.2.6",
    "plotly.js": "^3.5.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  },
  "eslintConfig": {
    "env": {
      "es2022": true,
      "node": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": 2022
    }
  }
}
