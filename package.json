{
  "name": "math4js",
  "version": "0.1.0",
  "description": "A JavaScript/Node.js math library",
  "main": "src/math4js/__init__.js",
  "scripts": {
    "test": "jest",
    "lint": "eslint src test",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "math",
    "statistics",
    "random"
  ],
  "author": "ccc-js",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "jstat": "^1.9.6",
    "numeric": "^1.2.6",
    "plotly.js": "^3.5.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  },
  "eslintConfig": {
    "env": {
      "es2022": true,
      "node": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": 2022
    }
  }
}
